{
  "name": "@inventoryflow/catalog-ingest",
  "version": "0.1.0",
  "private": true,
  "description": "InventoryFlow catalog ingestion pipeline — Track A (JD-native TypeScript)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "lint:fix": "eslint src test --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/storage/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "ingest": "tsx src/cli/ingest.ts",
    "ingest:dryrun": "tsx src/cli/ingest.ts --dry-run",
    "worker": "tsx src/queue/workers/main.ts",
    "api": "tsx src/api/server.ts",
    "dev": "tsx watch src/api/server.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.2",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^4.5.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.2",
    "p-limit": "^6.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "unzipper": "^0.12.3",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
