# ────────────────────────────────────────────────────────────────
# Track A — Environment configuration
# Copy to .env and edit. Never commit .env.
# ────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
LOG_LEVEL=info             # trace|debug|info|warn|error
APP_PORT=3000

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://dev:dev@localhost:5432/catalog
DB_POOL_SIZE=10

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Object storage — MinIO locally as R2 stand-in
# To target real R2: change endpoint + creds, keep bucket name
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=catalog
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true  # required for MinIO

# LLM provider
# Options: mock | cached | claude-code-handoff | ollama | gemini | anthropic
# Default (cached) hits the committed SQLite cache → zero API calls
LLM_PROVIDER=cached

# Provider-specific (only required when used)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2-vl:7b

# GEMINI_API_KEY=             # free tier from ai.google.dev
# ANTHROPIC_API_KEY=          # production target only

# Cache
LLM_CACHE_PATH=../shared/llm-cache.sqlite

# OpenTelemetry (optional)
OTEL_SERVICE_NAME=inventoryflow-catalog-ingest
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
