# ────────────────────────────────────────────────────────────────
# Track B v2 — Environment configuration
# Copy to .env and edit. Never commit .env.
# ────────────────────────────────────────────────────────────────

# Python / Poetry
PYTHONPATH=./dagster_project:./streaming

# PostgreSQL (gold-layer sync target + Debezium source DB)
DATABASE_URL=postgres://dev:dev@localhost:5432/catalog

# ────────────────────────────────────────────────────────────────
# Object storage — MinIO locally as R2 stand-in
# ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET_RAW=catalog-raw
S3_BUCKET_WAREHOUSE=catalog-warehouse     # Iceberg warehouse root
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ────────────────────────────────────────────────────────────────
# Iceberg catalog
# ────────────────────────────────────────────────────────────────
ICEBERG_CATALOG_TYPE=rest                  # rest | glue | hadoop
ICEBERG_CATALOG_URI=http://localhost:8181  # Iceberg REST catalog
ICEBERG_WAREHOUSE_LOCATION=s3://catalog-warehouse/
ICEBERG_NAMESPACE=inventoryflow

# ────────────────────────────────────────────────────────────────
# Dagster
# ────────────────────────────────────────────────────────────────
DAGSTER_HOME=./.dagster                    # local dev only
DAGSTER_WEBSERVER_PORT=3000

# ────────────────────────────────────────────────────────────────
# dbt
# ────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev                              # dev | prod

# ────────────────────────────────────────────────────────────────
# Redpanda (Kafka-compatible event bus)
# ────────────────────────────────────────────────────────────────
REDPANDA_BROKER=localhost:9092
REDPANDA_TOPIC_INVENTORY=inventory.changes
REDPANDA_TOPIC_PRICING=pricing.updates
REDPANDA_TOPIC_ORDERS=orders.placed
REDPANDA_TOPIC_CDC_PREFIX=postgres.cdc.    # Debezium publishes here

# ────────────────────────────────────────────────────────────────
# RisingWave (streaming SQL engine)
# ────────────────────────────────────────────────────────────────
RISINGWAVE_HOST=localhost
RISINGWAVE_PORT=4566                        # Postgres-wire protocol
RISINGWAVE_USER=root
RISINGWAVE_DB=dev

# ────────────────────────────────────────────────────────────────
# Kafka Connect (Debezium Postgres connector)
# ────────────────────────────────────────────────────────────────
KAFKA_CONNECT_URL=http://localhost:8083

# ────────────────────────────────────────────────────────────────
# OpenLineage emit
# ────────────────────────────────────────────────────────────────
OPENLINEAGE_URL=http://localhost:5000       # Marquez (deferred); use stdout for PoC
OPENLINEAGE_NAMESPACE=inventoryflow-track-b

# ────────────────────────────────────────────────────────────────
# LLM provider (shared abstraction with Track A — Python port)
# ────────────────────────────────────────────────────────────────
LLM_PROVIDER=cached                         # mock | cached | claude-code-handoff | ollama | gemini | anthropic
LLM_CACHE_PATH=../shared/llm-cache.sqlite

# Provider-specific (only if used)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2-vl:7b
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
