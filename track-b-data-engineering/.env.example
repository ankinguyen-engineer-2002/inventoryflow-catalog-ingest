# ────────────────────────────────────────────────────────────────
# Track B — Environment configuration
# Copy to .env and edit. Never commit .env.
# ────────────────────────────────────────────────────────────────

# Python / Poetry
PYTHONPATH=./pipelines:./orchestration

# PostgreSQL (gold-layer sync target)
DATABASE_URL=postgres://dev:dev@localhost:5432/catalog

# Object storage — MinIO locally as R2 stand-in
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET_RAW=catalog-raw
S3_BUCKET_BRONZE=catalog-bronze
S3_BUCKET_SILVER=catalog-silver
S3_BUCKET_GOLD=catalog-gold
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Delta Lake storage location
DELTA_TABLE_ROOT=s3://catalog-bronze

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# dbt
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev   # dev | prod

# LLM provider (shared abstraction with Track A)
LLM_PROVIDER=cached
LLM_CACHE_PATH=../shared/llm-cache.sqlite

# Great Expectations
GE_DATA_CONTEXT_ROOT=./pipelines/great_expectations
